<https://markuswilhelmjahn.github.io/bblocks-pdes/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - FiniteDifferenceMethod4PDES — OGC Building Block Register" ;
    dct:abstract """OGC Building Block register for all ODE/PDE models implemented in FiniteDifferenceMethod4PDES (Java/Maven, MVC architecture). Covers 22 local kinetic models across 4 complexity tiers, 4 Holling functional response components, and 2 spatial operators, all described using SOSA, PROV-O and STAC 1.0.
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-05-20T15:28:27.831710"^^xsd:dateTime ;
    owl:imports <https://opengeospatial.github.io/bblocks/register.json> ;
