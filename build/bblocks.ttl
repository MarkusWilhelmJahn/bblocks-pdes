        <bblocks://mwj.pdes.o2.scheffer>,
        <bblocks://mwj.pdes.o2.tannentriebwickler>,
        <bblocks://mwj.pdes.o2.tumor>,
        <bblocks://mwj.pdes.o2.volterra>,
        <bblocks://mwj.pdes.o3.fischfang>,
        <bblocks://mwj.pdes.o3.schloegl>,
        <bblocks://mwj.pdes.standard.exponential>,
        <bblocks://mwj.pdes.standard.goal-seeking>,
        <bblocks://mwj.pdes.standard.linear>,
        <bblocks://mwj.pdes.standard.logistic> ;
